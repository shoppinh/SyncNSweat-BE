# PostgreSQL (docker-compose)
POSTGRES_DB=syncnsweat
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URI=postgresql://postgres:postgres@db:5432/syncnsweat

# App settings
SECRET_KEY=change-me
API_URL=http://localhost:8000
SPOTIFY_REDIRECT_URL=http://localhost:8000
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Spotify API
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Exercise API
EXERCISE_API_KEY=
EXERCISE_API_HOST=

# Gemini API
GEMINI_API_KEY=
DEFAULT_SPOTIFY_USER_PASSWORD=

# Async workout pipeline / RabbitMQ (out of scope for this compose setup)
USE_ASYNC_WORKOUT_PIPELINE=false
ASYNC_PIPELINE_STRICT_MODE=false
ASYNC_PIPELINE_ROLLOUT_PERCENT=100
RABBITMQ_URL=amqp://guest:guest@localhost/
RABBITMQ_EXCHANGE_NAME=syncnsweat.events
